# Groq — chat / explanations / coaching
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Pinecone — integrated-embedding vector DB for paper abstract similarity search
# Index must be created with model=llama-text-embed-v2, dimension=1024, metric=cosine, field map "text"
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=scholarpath-abstracts
PINECONE_HOST=your-pinecone-index-host-here

# Supabase — Google Auth + Postgres (profiles, sessions, scores)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Semantic Scholar — optional. Keyless search works; a free API key raises the
# shared rate-limited pool to a dedicated ~1 req/sec for uniqueness search.
# SEMANTIC_SCHOLAR_API_KEY=
