# Groq — chat / explanations / coaching
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Pinecone — vector DB for paper abstract similarity search
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=scholarpath-abstracts
PINECONE_HOST=your-pinecone-index-host-here

# Firebase client config (from Firebase console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id-here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id-here

# Firebase Admin — paste entire service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT=your-firebase-service-account-json-here
